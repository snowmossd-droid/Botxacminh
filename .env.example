# Copy file nay thanh ".env" va dien gia tri that vao (KHONG commit file .env len GitHub)

# Token cua bot, lay tu https://discord.com/developers/applications
DISCORD_TOKEN=

# Application ID / Client ID cua bot (trong tab "General Information" cua Developer Portal)
CLIENT_ID=

# ID server (chuot phai vao ten server -> Copy Server ID, can bat Developer Mode)
# De trong neu muon slash command dang ky global (dung cho nhieu server, mat toi ~1h de cap nhat)
GUILD_ID=

# ID role se gan cho thanh vien SAU KHI xac minh xong
VERIFIED_ROLE_ID=

# ID role gan cho thanh vien MOI (chua xac minh) - de gioi han quyen. De trong neu khong dung
UNVERIFIED_ROLE_ID=

# ID kenh de gui tin nhan xac minh (nut bam)
VERIFY_CHANNEL_ID=

# ID kenh gui thong bao chao mung / tam biet
WELCOME_CHANNEL_ID=

# ID kenh gui canh bao anti-raid cho admin/mod
ALERT_CHANNEL_ID=

# So thanh vien join toi da trong khoang thoi gian RAID_WINDOW_MS truoc khi bi coi la raid
RAID_JOIN_THRESHOLD=8

# Khoang thoi gian (mili-giay) de tinh raid, mac dinh 10000 = 10 giay
RAID_WINDOW_MS=10000
